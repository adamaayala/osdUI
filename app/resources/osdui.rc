// ── Preflight dialog ────────────────────────────────────────────────────────

IDD_PREFLIGHT DIALOG 0, 0, 320, 220
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT "", IDC_TITLE_LABEL, 7, 7, 306, 20
    CONTROL "", IDC_PREFLIGHT_LIST, "SysListView32",
            LVS_REPORT | WS_BORDER | WS_TABSTOP, 7, 30, 306, 150
    DEFPUSHBUTTON "OK", IDOK, 209, 199, 50, 14
    PUSHBUTTON "Cancel", IDCANCEL, 263, 199, 50, 14
END

// ── App Tree dialog ─────────────────────────────────────────────────────────

IDD_APP_TREE DIALOG 0, 0, 320, 280
