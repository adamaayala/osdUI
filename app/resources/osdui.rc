#include "resource.h"
#include <windows.h>

// ── User Info dialog ────────────────────────────────────────────────────────

IDD_USER_INFO DIALOG 0, 0, 300, 150
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT "", IDC_TITLE_LABEL, 7, 7, 286, 20
    LTEXT "", IDC_INFO_TEXT, 7, 30, 286, 80
    DEFPUSHBUTTON "OK", IDOK, 189, 129, 50, 14
    PUSHBUTTON "Cancel", IDCANCEL, 243, 129, 50, 14
END

